# Default: treat all files as text and normalize to LF in the repo and on checkout.
* text=auto eol=lf

# Windows-specific scripts must keep CRLF endings.
*.ps1  text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Common binary types — never touch line endings.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.db   binary
