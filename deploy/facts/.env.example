# hugr facts store — environment template.
# Copy to `deploy/facts/.env` (gitignored) and set a real password:
#   cp deploy/facts/.env.example deploy/facts/.env
#
# Generate a strong password, e.g.:
#   openssl rand -base64 24
#
# POSTGRES_PASSWORD is required — the stack refuses to start without it, so no
# default password ever ships. The store is loopback-only; this password gates
# TCP connections from the host (e.g. the hugr CLI in PV-2). psql run *inside*
# the container over the local socket is trusted and needs no password.
POSTGRES_PASSWORD=

# Optional: host-side port for loopback connections (container listens on 5432).
# HUGR_FACTS_PORT=5432
